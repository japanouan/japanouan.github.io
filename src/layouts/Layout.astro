---
import "../styles/global.css";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="en" data-grid="on">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Chaiyapong Jaroonrotjananan | Full Stack Developer</title>

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Rajdhani:wght@500;600;700&family=Space+Grotesk:wght@400;500;600&display=swap" rel="stylesheet">
	</head>
	<body>
		<canvas id="bg"></canvas>
		<div class="fx"></div>

		<Sidebar />
		<main class="shell">
			<slot />
		</main>
		<Footer />

		<script>
			/* ---------- animated grid + particle background ---------- */
			(function () {
				const cv = document.getElementById('bg') as HTMLCanvasElement;
				const ctx = cv.getContext('2d')!;
				let w: number, h: number, dpr: number, parts: { x: number; y: number; vx: number; vy: number; r: number }[] = [], t = 0;
				function accent() {
					return getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#39ff14';
				}
				function hexRGB(hex: string) {
					hex = hex.replace('#', '');
					if (hex.length === 3) hex = hex.split('').map((c) => c + c).join('');
					const n = parseInt(hex, 16);
					return [n >> 16 & 255, n >> 8 & 255, n & 255];
				}
				function resize() {
					dpr = Math.min(window.devicePixelRatio || 1, 2);
					w = cv.width = innerWidth * dpr;
					h = cv.height = innerHeight * dpr;
					cv.style.width = innerWidth + 'px';
					cv.style.height = innerHeight + 'px';
					const count = Math.min(70, Math.floor((innerWidth * innerHeight) / 26000));
					parts = Array.from({ length: count }, () => ({
						x: Math.random() * w,
						y: Math.random() * h,
						vx: (Math.random() - 0.5) * 0.16 * dpr,
						vy: (Math.random() - 0.5) * 0.16 * dpr,
						r: (Math.random() * 1.6 + 0.5) * dpr,
					}));
				}
				function draw() {
					t += 1;
					ctx.clearRect(0, 0, w, h);
					const [r, g, b] = hexRGB(accent());
					const gap = 46 * dpr, off = (t * 0.22) % gap;
					ctx.lineWidth = 1;
					ctx.strokeStyle = `rgba(${r},${g},${b},0.035)`;
					ctx.beginPath();
					for (let x = -off; x < w; x += gap) { ctx.moveTo(x, 0); ctx.lineTo(x, h); }
					for (let y = -off; y < h; y += gap) { ctx.moveTo(0, y); ctx.lineTo(w, y); }
					ctx.stroke();
					for (const p of parts) {
						p.x += p.vx; p.y += p.vy;
						if (p.x < 0) p.x = w; if (p.x > w) p.x = 0;
						if (p.y < 0) p.y = h; if (p.y > h) p.y = 0;
						ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, 7);
						ctx.fillStyle = `rgba(${r},${g},${b},0.5)`;
						ctx.fill();
					}
					const maxd = 130 * dpr;
					for (let i = 0; i < parts.length; i++) for (let j = i + 1; j < parts.length; j++) {
						const a = parts[i], c = parts[j], dx = a.x - c.x, dy = a.y - c.y, d = Math.hypot(dx, dy);
						if (d < maxd) {
							ctx.strokeStyle = `rgba(${r},${g},${b},${0.10 * (1 - d / maxd)})`;
							ctx.beginPath(); ctx.moveTo(a.x, a.y); ctx.lineTo(c.x, c.y); ctx.stroke();
						}
					}
					requestAnimationFrame(draw);
				}
				addEventListener('resize', resize); resize(); draw();
			})();

			/* ---------- scroll reveal (with safety fallbacks) ---------- */
			(function () {
				const els = [...document.querySelectorAll<HTMLElement>('.reveal:not(.in)')];
				const show = (el: HTMLElement) => el.classList.add('in');
				const inView = (el: HTMLElement) => {
					const r = el.getBoundingClientRect();
					return r.top < innerHeight * 0.92 && r.bottom > 0;
				};
				els.forEach((el) => { if (inView(el)) show(el); });
				if (!('IntersectionObserver' in window)) { els.forEach(show); return; }
				const io = new IntersectionObserver((es) => {
					es.forEach((e) => { if (e.isIntersecting) { show(e.target as HTMLElement); io.unobserve(e.target); } });
				}, { rootMargin: '0px 0px -8% 0px', threshold: 0.06 });
				els.forEach((el) => { if (!el.classList.contains('in')) io.observe(el); });
				const onScroll = () => { els.forEach((el) => { if (!el.classList.contains('in') && inView(el)) show(el); }); };
				addEventListener('scroll', onScroll, { passive: true });
				setTimeout(() => els.forEach(show), 4000);
			})();
		</script>
	</body>
</html>

<style is:global>
	:root {
		--bg: #0a0a0a;
		--bg-2: #0e0e0e;
		--panel: #121212;
		--panel-2: #171717;
		--line: rgba(255, 255, 255, .07);
		--line-2: rgba(255, 255, 255, .12);
		--text: #e9eae8;
		--muted: #8c8f8a;
		--faint: #5a5d58;
		--accent: #39ff14;
		--glow: 1;
		--sidebar-w: 230px;
		--acc-soft: color-mix(in srgb, var(--accent) 14%, transparent);
		--acc-line: color-mix(in srgb, var(--accent) 38%, transparent);
		--disp: 'Rajdhani', sans-serif;
		--body: 'Space Grotesk', sans-serif;
		--mono: 'JetBrains Mono', monospace;
	}
	* { box-sizing: border-box; margin: 0; padding: 0; }
	html { scroll-behavior: smooth; }
	body {
		background: var(--bg);
		color: var(--text);
		font-family: var(--body);
		line-height: 1.6;
		-webkit-font-smoothing: antialiased;
		overflow-x: hidden;
	}
	::selection { background: var(--accent); color: #000; }
	a { color: inherit; text-decoration: none; }
	ul { list-style: none; }
	h1, h2, h3, h4, h5 { font-family: var(--disp); }

	canvas#bg { position: fixed; inset: 0; width: 100%; height: 100%; z-index: 0; pointer-events: none; }
	html[data-grid="off"] canvas#bg { display: none; }
	.fx { position: fixed; inset: 0; z-index: 1; pointer-events: none; }
	.fx::before {
		content: ""; position: absolute; inset: 0;
		background: repeating-linear-gradient(0deg, rgba(0,0,0,0) 0px, rgba(0,0,0,0) 2px, rgba(0,0,0,.22) 3px, rgba(0,0,0,0) 4px);
		opacity: .5; mix-blend-mode: multiply;
	}
	.fx::after {
		content: ""; position: absolute; inset: 0;
		background: radial-gradient(120% 90% at 50% 0%, transparent 55%, rgba(0,0,0,.55) 100%);
	}

	/* ---------- SHELL ---------- */
	.shell { margin-left: var(--sidebar-w); position: relative; z-index: 5; }
	section { padding: 130px 8vw 130px; max-width: 1180px; margin-inline: auto; position: relative; }
	.eyebrow {
		display: inline-flex; align-items: center; gap: 10px;
		font-family: var(--mono); font-size: 11px; letter-spacing: 3px; color: var(--accent);
		margin-bottom: 26px; text-transform: uppercase;
	}
	.eyebrow::before { content: ""; width: 26px; height: 1px; background: var(--acc-line); }
	.eyebrow .num { color: var(--faint); }
	h2.sec { font-family: var(--disp); font-weight: 700; font-size: clamp(34px, 5vw, 58px); letter-spacing: 1px; line-height: 1; text-transform: uppercase; margin-bottom: 34px; }

	/* reveal */
	.reveal { opacity: 0; transform: translateY(26px); transition: opacity .7s ease, transform .7s cubic-bezier(.2,.7,.2,1); }
	.reveal.in { opacity: 1; transform: none; }
	.reveal.d1 { transition-delay: .08s; } .reveal.d2 { transition-delay: .16s; } .reveal.d3 { transition-delay: .24s; } .reveal.d4 { transition-delay: .32s; }
	@media (prefers-reduced-motion: reduce) { .reveal { opacity: 1 !important; transform: none !important; transition: none; } }

	@media (max-width: 760px) {
		:root { --sidebar-w: 0px; }
		.shell, footer { margin-left: 0 !important; }
		section { padding: 90px 7vw; }
	}
</style>
