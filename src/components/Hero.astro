---
---

<section id="home">
  <div class="hero">
    <div class="hero-status reveal in"><span class="led"></span> SYSTEM ONLINE · PORTFOLIO_v1.0</div>
    <h1 class="reveal in d1">CHAIYAPONG<span class="ln2">JAROONROTJANANAN</span></h1>
    <div class="role reveal in d2">
      <span class="pre">&gt;</span>
      <span class="txt" id="role-txt"></span><span class="cur"></span>
    </div>
    <p class="lede reveal in d3">
      A Junior Software Engineer who enjoys building backend systems, tuning
      performance, and managing databases, dedicated to writing clean, secure,
      and efficient code.
    </p>
    <div class="hero-meta reveal in d3">
      <span class="chip"><b>◢</b> THAILAND</span>
      <span class="chip"><b>◢</b> BACKEND FOCUS</span>
      <span class="chip"><b>◢</b> PERFORMANCE TUNING</span>
    </div>
    <div class="cta-row reveal in d4">
      <a href="#projects" class="btn">VIEW PROJECTS</a>
      <a href="/resume.pdf" target="_blank" class="btn ghost" hidden>DOWNLOAD CV</a>
    </div>
  </div>
  <div class="hero-art reveal in d2">
    <div class="hud-frame">
      <span class="hud-coord">ID · 0xCJ</span>
      <img class="avatar-img" src="/images/avatar.png" alt="Chaiyapong Jaroonrotjananan" />
      <span class="hud-tag">PLAYER_01</span>
    </div>
  </div>
</section>

<script>
  const roles = ["Backend Developer", "Full Stack Developer", "Software Engineer"];
  let ri = 0, ci = 0, del = false;
  function tick() {
    const el = document.getElementById("role-txt");
    if (!el) return;
    const word = roles[ri];
    el.textContent = word.slice(0, ci);
    if (!del) {
      ci++;
      if (ci > word.length) { del = true; return setTimeout(tick, 1300); }
    } else {
      ci--;
      if (ci < 0) { del = false; ri = (ri + 1) % roles.length; ci = 0; return setTimeout(tick, 260); }
    }
    setTimeout(tick, del ? 42 : 78);
  }
  tick();
</script>

<style>
  #home { min-height: 100vh; display: grid; grid-template-columns: 1.3fr .9fr; align-items: center; gap: 60px; padding-top: 90px; padding-bottom: 90px; }
  .hero-status { font-family: var(--mono); font-size: 11px; letter-spacing: 2px; color: var(--muted); margin-bottom: 24px; display: flex; align-items: center; gap: 10px; }
  .hero-status .led { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 calc(9px*var(--glow)) var(--accent); animation: pulse 1.8s infinite; }
  .hero h1 { font-family: var(--disp); font-weight: 700; font-size: clamp(38px, 5.4vw, 76px); line-height: .9; letter-spacing: .5px; text-transform: uppercase; white-space: nowrap; }
  .hero h1 .ln2 { display: block; font-size: clamp(26px, 4vw, 56px); letter-spacing: .3px; color: transparent; -webkit-text-stroke: 1.2px var(--accent); text-stroke: 1.2px var(--accent); filter: drop-shadow(0 0 calc(14px*var(--glow)) var(--acc-soft)); }
  .role { height: 38px; margin: 22px 0 12px; font-family: var(--mono); font-size: clamp(15px, 2vw, 20px); letter-spacing: 1px; color: var(--text); display: flex; align-items: center; gap: 12px; }
  .role .pre { color: var(--accent); }
  .role .txt { position: relative; }
  .role .cur { display: inline-block; width: 10px; height: 1.05em; background: var(--accent); margin-left: 3px; transform: translateY(2px); animation: blink 1s steps(1) infinite; box-shadow: 0 0 calc(7px*var(--glow)) var(--accent); }
  @keyframes blink { 50% { opacity: 0; } }
  .hero p.lede { color: var(--muted); max-width: 440px; margin-top: 14px; font-size: 15.5px; }
  .hero-meta { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 26px; }
  .chip { font-family: var(--mono); font-size: 11px; letter-spacing: 1px; color: var(--muted); border: 1px solid var(--line-2); padding: 7px 13px; display: inline-flex; align-items: center; gap: 8px; background: rgba(255,255,255,.015); }
  .chip b { color: var(--accent); font-weight: 500; }
  .cta-row { display: flex; gap: 14px; margin-top: 34px; flex-wrap: wrap; }
  .btn {
    font-family: var(--mono); font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase;
    padding: 14px 24px; border: 1px solid var(--acc-line); color: var(--accent);
    display: inline-flex; align-items: center; gap: 10px; cursor: pointer; background: transparent;
    transition: .22s; position: relative;
  }
  .btn::before { content: "["; opacity: .5; } .btn::after { content: "]"; opacity: .5; }
  .btn:hover { background: var(--acc-soft); box-shadow: 0 0 calc(20px*var(--glow)) var(--acc-soft); color: #caffbe; }
  .btn.ghost { border-color: var(--line-2); color: var(--muted); }
  .btn.ghost:hover { color: var(--text); box-shadow: none; background: rgba(255,255,255,.03); }

  /* avatar HUD frame */
  .hero-art { position: relative; justify-self: center; }
  .hud-frame { position: relative; width: 330px; max-width: 38vw; aspect-ratio: 4/5; padding: 12px; border: 1px solid var(--line-2); background: linear-gradient(160deg, var(--panel), var(--bg-2)); }
  .hud-frame::before, .hud-frame::after { content: ""; position: absolute; width: 18px; height: 18px; border: 2px solid var(--accent); filter: drop-shadow(0 0 calc(6px*var(--glow)) var(--acc-soft)); }
  .hud-frame::before { top: -1px; left: -1px; border-right: none; border-bottom: none; }
  .hud-frame::after { bottom: -1px; right: -1px; border-left: none; border-top: none; }
  .avatar-img {
    width: 100%; height: 100%; display: block; object-fit: contain;
    background: repeating-linear-gradient(45deg, rgba(255,255,255,.02) 0 2px, transparent 2px 12px);
  }
  .hud-tag { position: absolute; left: 12px; bottom: -12px; font-family: var(--mono); font-size: 9.5px; letter-spacing: 1.5px; color: var(--accent); background: var(--bg); padding: 3px 9px; border: 1px solid var(--acc-line); }
  .hud-coord { position: absolute; right: 12px; top: -12px; font-family: var(--mono); font-size: 9px; letter-spacing: 1px; color: var(--muted); background: var(--bg); padding: 3px 8px; border: 1px solid var(--line-2); }

  @media (max-width: 980px) {
    #home { grid-template-columns: 1fr; }
    .hero-art { display: none; }
  }
  @media (max-width: 760px) {
    #home { min-height: auto; padding-top: 110px; }
  }
</style>
