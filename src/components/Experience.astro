---
const experiences = [
  {
    position: "Full-stack Developer (Cooperative Education)",
    company: "App Intouch Co., Ltd.",
    startDate: "2025-11-01",
    endDate: "2026-03-31",
    achievements: [
      "Developed and improved the corporate budget management system using ASP.NET Core (C#), Razor, and a relational database.",
      "Refactored complex business logic and data processing rules to seamlessly accommodate evolving client requirements.",
      "Upgraded the budget reporting module, refactoring 7–8 legacy reports and designing 2 new high-fidelity dynamic reports.",
      "Developed an automated Excel export engine with custom formatting for direct financial analysis.",
      "Improved UI layouts and data ordering hierarchies to enhance information readability and cognitive accuracy for end-users.",
      "Enhanced system loading performance by implementing tab-based Lazy Loading, reducing initial page latency and creating a fluid UI experience.",
      "Collaborated with internal APIs to retrieve, process, and bind database assets for dynamic reporting and data presentation."
    ],
    tech: [".NET Core", "C#", "Oracle SQL", "Azure DevOps (Version Control)", "Razor Pages"]
  }
];

function formatPeriod(startDateStr: string, endDateStr: string) {
  const start = new Date(startDateStr);
  const end = new Date(endDateStr);
  
  const startYear = start.getFullYear();
  const endYear = end.getFullYear();
  
  const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
  const startMonth = months[start.getMonth()];
  const endMonth = months[end.getMonth()];
  
  // Calculate total months difference
  const diffInMonths = (endYear - startYear) * 12 + (end.getMonth() - start.getMonth());
  const yearsDiff = diffInMonths / 12;
  
  if (yearsDiff <= 2) {
    if (startYear === endYear) {
      return `${startMonth} - ${endMonth} ${startYear}`;
    } else {
      return `${startMonth} ${startYear} - ${endMonth} ${endYear}`;
    }
  } else {
    return `${startYear} - ${endYear}`;
  }
}
---

<section id="experience" class="container">
  <h2 class="section-title fade-in">Experience</h2>
  
  <div class="experience-list fade-in">
    {
      experiences.map((exp) => (
        <div class="experience-card">
          <div class="experience-left">
            <span class="experience-time">{formatPeriod(exp.startDate, exp.endDate)}</span>
          </div>
          <div class="experience-right">
            <h3 class="experience-title">
              {exp.position} <span class="divider">·</span> <span class="company">{exp.company}</span>
            </h3>
            
            {exp.achievements ? (
              <ul class="experience-bullets">
                {exp.achievements.map((bullet) => (
                  <li>{bullet}</li>
                ))}
              </ul>
            ) : (
              <p class="experience-desc"></p>
            )}

            <div class="experience-badges">
              {exp.tech.map((tech) => (
                <span class="badge">{tech}</span>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .container {
    padding-bottom: 50px;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    position: relative;
  }

  .experience-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
  }

  .experience-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background-color: transparent;
    transition: background-color 0.3s ease;
  }

  .experience-card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 12px 30px rgba(0, 0, 0, 0.04);
  }

  .experience-card:hover::before {
    background-color: var(--accent);
  }

  .experience-left {
    flex: 0 0 auto;
  }

  .experience-time {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.5px;
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background-color: rgba(59, 130, 246, 0.08);
    border-radius: 6px;
    border: 1px solid rgba(59, 130, 246, 0.15);
  }

  .experience-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .experience-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .experience-title .divider {
    color: var(--accent);
    margin: 0 0.25rem;
  }

  .experience-title .company {
    color: var(--text-primary);
    opacity: 0.9;
  }

  .experience-bullets {
    list-style-type: disc;
    padding-left: 1.25rem;
    color: var(--text-secondary);
    font-size: 0.98rem;
    line-height: 1.75;
    margin-bottom: 0.75rem;
  }

  .experience-bullets li {
    margin-bottom: 0.5rem;
  }

  .experience-bullets li::marker {
    color: var(--accent);
  }

  .experience-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  .experience-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .badge {
    background-color: rgba(59, 130, 246, 0.1);
    color: var(--accent);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .badge:hover {
    background-color: var(--accent);
    color: #fff;
  }

  /* Responsive layout for tablet and desktop */
  @media (min-width: 768px) {
    .experience-card {
      flex-direction: row;
      gap: 3rem;
      align-items: flex-start;
    }

    .experience-left {
      flex: 0 0 200px;
      text-align: left;
    }

    .experience-time {
      padding: 0;
      background-color: transparent;
      border: none;
      font-size: 1.15rem;
      color: var(--text-secondary);
    }

    .experience-card:hover .experience-time {
      color: var(--accent);
    }
  }
</style>
