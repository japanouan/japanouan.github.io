---
const experiences = [
  {
    position: "Full-stack Developer (Cooperative Education)",
    company: "App Intouch Co., Ltd.",
    startDate: "2025-11-01",
    endDate: "2026-03-31",
    achievements: [
      "Developed and improved the corporate budget management system using ASP.NET Core (C#), Razor, and a relational database.",
      "Refactored complex business logic and data processing rules to seamlessly accommodate evolving client requirements.",
      "Upgraded the budget reporting module, refactoring 7–8 legacy reports and designing 2 new high-fidelity dynamic reports.",
      "Developed an automated Excel export engine with custom formatting for direct financial analysis.",
      "Improved UI layouts and data ordering hierarchies to enhance information readability and cognitive accuracy for end-users.",
      "Enhanced system loading performance by implementing tab-based Lazy Loading, reducing initial page latency and creating a fluid UI experience.",
      "Collaborated with internal APIs to retrieve, process, and bind database assets for dynamic reporting and data presentation.",
    ],
    tech: [".NET Core", "C#", "Oracle SQL", "Azure DevOps (Version Control)", "Razor Pages"],
  },
  {
    position: "B.Eng. Computer Engineering",
    company: "Kasetsart University (Kamphaeng Saen Campus)",
    startDate: "2022-06-01",
    endDate: "2026-03-31",
    achievements: null,
    tech: [],
  },
];

function formatPeriod(startDateStr: string, endDateStr: string) {
  const start = new Date(startDateStr);
  const end = new Date(endDateStr);

  const startYear = start.getFullYear();
  const endYear = end.getFullYear();

  const months = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
  const startMonth = months[start.getMonth()];
  const endMonth = months[end.getMonth()];

  const diffInMonths = (endYear - startYear) * 12 + (end.getMonth() - start.getMonth());
  const yearsDiff = diffInMonths / 12;

  if (yearsDiff <= 2) {
    if (startYear === endYear) {
      return `${startMonth} - ${endMonth} ${startYear}`;
    } else {
      return `${startMonth} ${startYear} - ${endMonth} ${endYear}`;
    }
  } else {
    return `${startYear} - ${endYear}`;
  }
}
---

<section id="experience">
  <div class="eyebrow reveal"><span class="num">03</span> / EXPERIENCE</div>
  <h2 class="sec reveal d1">Run history</h2>
  <div class="timeline">
    {
      experiences.map((exp, i) => (
        <div class={`tl-item reveal d${i + 1}`}>
          <div class="when">{formatPeriod(exp.startDate, exp.endDate).toUpperCase()}</div>
          <h4>{exp.position}</h4>
          <div class="org">{exp.company}</div>
          {exp.achievements ? (
            <ul class="tl-bullets">
              {exp.achievements.map((bullet) => <li>{bullet}</li>)}
            </ul>
          ) : null}
          {exp.tech.length > 0 && (
            <div class="tl-badges">
              {exp.tech.map((tech) => <span class="badge">{tech}</span>)}
            </div>
          )}
        </div>
      ))
    }
  </div>
</section>

<style>
  .timeline { position: relative; margin-left: 8px; padding-left: 34px; }
  .timeline::before { content: ""; position: absolute; left: 0; top: 6px; bottom: 6px; width: 1px; background: linear-gradient(180deg, var(--acc-line), var(--line) 80%, transparent); }
  .tl-item { position: relative; padding-bottom: 42px; }
  .tl-item:last-child { padding-bottom: 0; }
  .tl-item::before { content: ""; position: absolute; left: -39px; top: 4px; width: 11px; height: 11px; border-radius: 50%; background: var(--bg); border: 2px solid var(--accent); box-shadow: 0 0 calc(11px*var(--glow)) var(--accent); }
  .tl-item .when { font-family: var(--mono); font-size: 11px; letter-spacing: 1.5px; color: var(--accent); margin-bottom: 7px; }
  .tl-item h4 { font-family: var(--disp); font-weight: 600; font-size: 22px; letter-spacing: .5px; }
  .tl-item .org { font-family: var(--mono); font-size: 12px; color: var(--muted); margin: 3px 0 11px; }
  .tl-bullets { list-style: disc; padding-left: 1.25rem; color: var(--muted); font-size: 14.5px; line-height: 1.75; max-width: 640px; margin-bottom: 14px; }
  .tl-bullets li { margin-bottom: .5rem; }
  .tl-bullets li::marker { color: var(--accent); }
  .tl-badges { display: flex; gap: 8px; flex-wrap: wrap; }
  .badge { font-family: var(--mono); font-size: 10px; letter-spacing: .5px; color: var(--accent); border: 1px solid var(--acc-line); background: var(--acc-soft); padding: 5px 10px; }
</style>
