  }

  .view-more-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    transition: gap 0.2s ease;
  }

  .project-card:hover .view-more-link {
    gap: 0.5rem;
  }

  .arrow-icon {
    transition: transform 0.2s ease;
  }

  /* === Modal Styles === */
  .project-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-modal.active {
    opacity: 1;
    pointer-events: auto;
  }

  .modal-backdrop {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(15, 17, 23, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .modal-container {
    position: relative;
    width: 90%;
    max-width: 750px;
    max-height: 85vh;
    background-color: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow-y: auto;
    z-index: 10000;
    transform: translateY(30px) scale(0.96);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.3);
  }

  .project-modal.active .modal-container {
    transform: translateY(0) scale(1);
  }

  .modal-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(15, 17, 23, 0.6);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: white;
    font-size: 1.6rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10005;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    line-height: 1;
    padding-bottom: 3px;
  }

  .modal-close:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
    transform: rotate(90deg) scale(1.05);
  }

  .modal-image-wrapper {
    width: 100%;
    aspect-ratio: 16 / 9;
    padding: 0 10px;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background-color: var(--bg-card);
    display: flex;
    flex-direction: column;
    /* align-items: ; */
    justify-content: center;
  }

  .modal-image {
    width: 100%;

    /* height: 100%; */
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .project-modal.active .modal-image {
    transform: scale(1.02);
  }

  .modal-body {
    padding: 2.5rem;
  }

  .modal-title {
    font-family: var(--font-heading);
    font-size: 1.65rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
    line-height: 1.35;
  }

  .modal-subtitle-text {
    font-size: 0.95rem;
    color: var(--text-secondary);
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .modal-section-label {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: var(--accent);
    margin-bottom: 0.75rem;
