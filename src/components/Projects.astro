  }

  .modal-badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .modal-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1.5rem;
  }

  .modal-responsibilities {
    list-style-type: disc;
    padding-left: 1.25rem;
    color: var(--text-secondary);
    font-size: 0.98rem;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .modal-responsibilities li {
    margin-bottom: 0.6rem;
  }

  .modal-responsibilities li::marker {
